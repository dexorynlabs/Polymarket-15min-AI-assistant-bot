# ─────────────────────────────────────────────────────────────────────────────
# Polymarket BTC 15m Assistant — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The bot loads .env automatically via dotenv. Just run: npm start
# ─────────────────────────────────────────────────────────────────────────────


# ── Polymarket market selection ───────────────────────────────────────────────
# Leave POLYMARKET_SLUG empty to auto-select the latest live BTC 15m market.
POLYMARKET_SLUG=
POLYMARKET_SERIES_ID=10192
POLYMARKET_SERIES_SLUG=btc-up-or-down-15m
POLYMARKET_AUTO_SELECT_LATEST=true
POLYMARKET_LIVE_WS_URL=wss://ws-live-data.polymarket.com
POLYMARKET_UP_LABEL=Up
POLYMARKET_DOWN_LABEL=Down


# ── Chainlink / Polygon RPC ───────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_URLS=
POLYGON_WSS_URL=
POLYGON_WSS_URLS=
CHAINLINK_BTC_USD_AGGREGATOR=0xc907E116054Ad103354f2D350FD2514433D57F6f


# ── Probability model ─────────────────────────────────────────────────────────
MODEL_REALIZED_VOL_LOOKBACK_MINUTES=30
MODEL_DRIFT_LOOKBACK_MINUTES=5
MODEL_MIN_VOL_PCT_PER_MINUTE=0.00035

# Student-t degrees of freedom for settlement probability CDF.
# Lower value = fatter tails = less overconfident on large price gaps.
# Range: 3–6 (4 is a good default for BTC). Set to ~30 to approximate normal.
MODEL_TAIL_DF=4

# TA score weight in the Bayesian probability blend (0 = pure model, 1 = pure TA).
# The blended probability drives all edge, EV, and Kelly calculations.
# Recommended: 0.20–0.30.
MODEL_TA_PROB_WEIGHT=0.25


# ── Kelly criterion position sizing ──────────────────────────────────────────
# Set to false to use fixed stake sizes (PAPER_TRADING_STAKE_USD / LIVE_MAX_STAKE_USD).
KELLY_ENABLED=true

# Fraction of full-Kelly to bet. 0.5 = half-Kelly (recommended for safety).
# Full Kelly (1.0) maximises long-run growth but has high variance.
KELLY_FRACTION=0.5

# Minimum stake per trade in USD (floor; prevents trivially small bets).
KELLY_MIN_STAKE_USD=5

# Reference bankroll for live Kelly sizing.
# Paper trading uses the live paper-cash balance automatically.
KELLY_LIVE_BANKROLL_USD=500


# ── Execution cost filters ────────────────────────────────────────────────────
EXECUTION_FEE_RATE=0.002
EXECUTION_SLIPPAGE_BPS=12
EXECUTION_MAX_SPREAD=0.035
EXECUTION_MIN_LIQUIDITY_SHARES=40
EXECUTION_MIN_NET_EV_USD=0.75
EXECUTION_MAX_REFERENCE_AGE_MS=6000
EXECUTION_COOLDOWN_MS=30000
# Comma-separated phases to allow trading: EARLY (>10 min), MID (5-10 min), LATE (0-5 min). Default: MID,LATE
EXECUTION_ALLOWED_PHASES=MID,LATE


# ── Paper trading ─────────────────────────────────────────────────────────────
PAPER_TRADING_ENABLED=true
PAPER_TRADING_STARTING_CASH=1000
PAPER_TRADING_STAKE_USD=25


# ── Live trading (disabled by default — enable only after paper testing) ──────
#
# STEP 1: Set LIVE_DRY_RUN=true and verify the dashboard shows "DRY RUN" status.
# STEP 2: Once satisfied, set LIVE_DRY_RUN=false to place real orders.
#
# To get your API credentials, run with the SAME wallet type and proxy you use:
#   LIVE_WALLET_TYPE=2 LIVE_PROXY_WALLET=0x... PRIVATE_KEY=0x... npm run derive-creds
# Then copy POLY_API_KEY, POLY_API_SECRET, POLY_API_PASSPHRASE into .env

LIVE_TRADING_ENABLED=false
LIVE_DRY_RUN=true

# Your Polygon wallet private key (required when LIVE_DRY_RUN=false)
PRIVATE_KEY=

# Polymarket CLOB L2 API credentials (generate with: npm run derive-creds)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Wallet type: 0 = EOA (standalone wallet), 1 = POLY_PROXY (Magic Link),
#              2 = POLY_GNOSIS_SAFE (MetaMask / browser wallet — most common)
LIVE_WALLET_TYPE=0

# Proxy/funder wallet address — REQUIRED for wallet types 1 and 2.
# For type 0 (EOA): leave empty; your EOA address is used automatically.
# For type 2: use your Polymarket proxy address (found in polymarket.com profile when logged in).
#            This is NOT your MetaMask address — it's the proxy Polymarket created for you.
LIVE_PROXY_WALLET=

# Order strategy: market order (FOK) first, then limit with aggression fallback.
LIVE_USE_MARKET_ORDER=true
LIVE_LIMIT_AGGRESSION_TICKS=3

# Risk controls
LIVE_MAX_STAKE_USD=25
LIVE_MAX_DAILY_LOSS_USD=50
LIVE_MAX_OPEN_POSITIONS=1


# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=./logs
LOG_SNAPSHOTS_ENABLED=true
LOG_RESULTS_ENABLED=true
LOG_TRADES_ENABLED=true


# ── Proxy (optional) ──────────────────────────────────────────────────────────
# Supports http://, https://, socks5:// URLs.
# HTTP_PROXY=http://user:pass@host:port
# HTTPS_PROXY=http://user:pass@host:port
